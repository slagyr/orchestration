# Connection details for the remote Isaac host (e.g. zanebot).
# This file is committed as a template. Copy to .env and edit.
# The real values are used by install.sh and by the agent following
# isaac-beans/test/happy-path.md.
host: host.example.com
user: joe

# Optional: override the target Isaac root (default: ~/.isaac)
# isaac-root: ~/.isaac

